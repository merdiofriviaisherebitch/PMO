# PMO Control Tower — environment template.
# Copy to `.env.local` and fill in real values. NEVER put real secrets in this file (it IS committed).
# What lives where:
#   - .env.local / Vercel  → the app's runtime values below
#   - Supabase Auth → Providers → custom OIDC  → Microsoft Entra tenant/client ID + secret (NOT here)
#   - Supabase Edge Function secrets (`supabase secrets set`) → RESEND_API_KEY, EDGE_SHARED_SECRET, MS_GRAPH_* (NOT here)
#   - Supabase auto-injects SUPABASE_URL / ANON_KEY / SERVICE_ROLE_KEY into Edge Functions — don't re-add there.

# === App ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000        # prod: https://<your-domain>
APP_TIMEZONE=Europe/Madrid                         # weekly cut-off timezone (CLAUDE.md §18 Q2)

# === Supabase (Phase 0/1) — Dashboard → Project Settings → API ===
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable / anon key>      # public, browser-safe
SUPABASE_SERVICE_ROLE_KEY=<service_role / secret key>       # SERVER ONLY — never NEXT_PUBLIC_
SUPABASE_DB_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=<project-ref>

# === Resend (Phase 5) — set as a Supabase Edge secret; here only if the app sends mail directly ===
RESEND_API_KEY=<re_...>
RESEND_FROM="PMO Control Tower <notifications@yourdomain>"

# === Edge <-> pg_net (Phase 5) — Supabase Edge secret + DB setting ===
EDGE_SHARED_SECRET=<openssl rand -hex 32>

# === Microsoft Entra SSO (Phase 1) — configured in Supabase Auth → Providers, NOT in this file ===
#   Gather: Directory (tenant) ID, Application (client) ID, Client secret,
#   issuer https://login.microsoftonline.com/<tenant>/v2.0, scopes: openid profile email offline_access

# === Microsoft Graph (Phase 8, full tier only) — Supabase Edge secrets ===
# MS_GRAPH_TENANT_ID=<tenant-id>
# MS_GRAPH_CLIENT_ID=<client-id>
# MS_GRAPH_CLIENT_SECRET=<client-secret>
